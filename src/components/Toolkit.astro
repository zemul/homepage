---
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="toolkit" class="py-16 px-4 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-10 text-center dark:text-white">{t("toolkit.title")}</h2>

    <div class="toolkit-groups">
        <!-- AI Subscriptions -->
        <div class="toolkit-group">
            <h3 class="toolkit-label">{t("toolkit.aiSubs")}</h3>
            <div class="toolkit-items">
                <div class="toolkit-pill">
                    <Icon name="simple-icons:claude" class="toolkit-icon icon-claude" />
                    <span class="toolkit-name">Claude Max + Pro</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:openai" class="toolkit-icon icon-openai" />
                    <span class="toolkit-name">ChatGPT Plus</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:googlegemini" class="toolkit-icon icon-gemini" />
                    <span class="toolkit-name">Google AI Pro</span>
                </div>
                <div class="toolkit-pill">
                    <svg class="toolkit-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <title>Doubao</title>
                        <path d="M5.31 15.756c.172-3.75 1.883-5.999 2.549-6.739-3.26 2.058-5.425 5.658-6.358 8.308v1.12C1.501 21.513 4.226 24 7.59 24a6.59 6.59 0 0 0 2.2-.375c.353-.12.7-.248 1.039-.378.913-.899 1.65-1.91 2.243-2.992-4.877 2.431-7.974.072-7.763-4.5l.002.001z" fill="#1E37FC" />
                        <path d="M22.57 10.283c-1.212-.901-4.109-2.404-7.397-2.8.295 3.792.093 8.766-2.1 12.773a12.782 12.782 0 0 1-2.244 2.992c3.764-1.448 6.746-3.457 8.596-5.219 2.82-2.683 3.353-5.178 3.361-6.66a2.737 2.737 0 0 0-.216-1.084v-.002z" fill="#37E1BE" />
                        <path d="M14.303 1.867C12.955.7 11.248 0 9.39 0 7.532 0 5.883.677 4.545 1.807 2.791 3.29 1.627 5.557 1.5 8.125v9.201c.932-2.65 3.097-6.25 6.357-8.307.5-.318 1.025-.595 1.569-.829 1.883-.801 3.878-.932 5.746-.706-.222-2.83-.718-5.002-.87-5.617h.001z" fill="#A569FF" />
                        <path d="M17.305 4.961a199.47 199.47 0 0 1-1.08-1.094c-.202-.213-.398-.419-.586-.622l-1.333-1.378c.151.615.648 2.786.869 5.617 3.288.395 6.185 1.898 7.396 2.8-1.306-1.275-3.475-3.487-5.266-5.323z" fill="#1E37FC" />
                    </svg>
                    <span class="toolkit-name">{lang === 'zh' ? '豆包' : 'Doubao'}</span>
                </div>
                <div class="toolkit-pill">
                    <svg class="toolkit-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <title>Qwen</title>
                        <path d="M12.604 1.34c.393.69.784 1.382 1.174 2.075a.18.18 0 0 0 .157.091h5.552c.174 0 .322.11.446.327l1.454 2.57c.19.337.24.478.024.837-.26.43-.513.864-.76 1.3l-.367.658c-.106.196-.223.28-.04.512l2.652 4.637c.172.301.111.494-.043.77-.437.785-.882 1.564-1.335 2.34-.159.272-.352.375-.68.37-.777-.016-1.552-.01-2.327.016a.099.099 0 0 0-.081.05 575.097 575.097 0 0 1-2.705 4.74c-.169.293-.38.363-.725.364-.997.003-2.002.004-3.017.002a.537.537 0 0 1-.465-.271l-1.335-2.323a.09.09 0 0 0-.083-.049H4.982c-.285.03-.553-.001-.805-.092l-1.603-2.77a.543.543 0 0 1-.002-.54l1.207-2.12a.198.198 0 0 0 0-.197 550.951 550.951 0 0 1-1.875-3.272l-.79-1.395c-.16-.31-.173-.496.095-.965.465-.813.927-1.625 1.387-2.436.132-.234.304-.334.584-.335a338.3 338.3 0 0 1 2.589-.001.124.124 0 0 0 .107-.063l2.806-4.895a.488.488 0 0 1 .422-.246c.524-.001 1.053 0 1.583-.006L11.704 1c.341-.003.724.032.9.34zm-3.432.403a.06.06 0 0 0-.052.03L6.254 6.788a.157.157 0 0 1-.135.078H3.253c-.056 0-.07.025-.041.074l5.81 10.156c.025.042.013.062-.034.063l-2.795.015a.218.218 0 0 0-.2.116l-1.32 2.31c-.044.078-.021.118.068.118l5.716.008c.046 0 .08.02.104.061l1.403 2.454c.046.081.092.082.139 0l5.006-8.76.783-1.382a.055.055 0 0 1 .096 0l1.424 2.53a.122.122 0 0 0 .107.062l2.763-.02a.04.04 0 0 0 .035-.02.041.041 0 0 0 0-.04l-2.9-5.086a.108.108 0 0 1 0-.113l.293-.507 1.12-1.977c.024-.041.012-.062-.035-.062H9.2c-.059 0-.073-.026-.043-.077l1.434-2.505a.107.107 0 0 0 0-.114L9.225 1.774a.06.06 0 0 0-.053-.031zm6.29 8.02c.046 0 .058.02.034.06l-.832 1.465-2.613 4.585a.056.056 0 0 1-.05.029.058.058 0 0 1-.05-.029L8.498 9.841c-.02-.034-.01-.052.028-.054l.216-.012 6.722-.012z" fill="url(#qwen-gradient)" fill-rule="nonzero" />
                        <defs>
                            <linearGradient id="qwen-gradient" x1="0%" x2="100%" y1="0%" y2="0%">
                                <stop offset="0%" stop-color="#6336E7" stop-opacity=".84" />
                                <stop offset="100%" stop-color="#6F69F7" stop-opacity=".84" />
                            </linearGradient>
                        </defs>
                    </svg>
                    <span class="toolkit-name">{lang === 'zh' ? '千问' : 'Qwen'}</span>
                </div>
                <div class="toolkit-pill">
                    <svg class="toolkit-icon icon-kimi" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                    <span class="toolkit-name">Kimi</span>
                </div>
            </div>
        </div>

        <!-- Daily Tools -->
        <div class="toolkit-group">
            <h3 class="toolkit-label">{t("toolkit.dailyTools")}</h3>
            <div class="toolkit-items">
                <div class="toolkit-pill">
                    <svg class="toolkit-icon icon-ghostty" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C8.13 2 5 5.13 5 9v11l2-2 2 2 2-2 2 2 2-2 2 2V9c0-3.87-3.13-7-7-7zm-2.5 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" />
                    </svg>
                    <span class="toolkit-name">Ghostty</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:openai" class="toolkit-icon icon-codex" />
                    <span class="toolkit-name">Codex</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:xcode" class="toolkit-icon icon-xcode" />
                    <span class="toolkit-name">Xcode</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:visualstudiocode" class="toolkit-icon icon-vscode" />
                    <span class="toolkit-name">VS Code</span>
                    <span class="toolkit-tag">{t("toolkit.vscodeNote")}</span>
                </div>
                <div class="toolkit-pill is-deprecated">
                    <Icon name="simple-icons:warp" class="toolkit-icon icon-warp" />
                    <span class="toolkit-name">Warp</span>
                    <span class="toolkit-dep">{t("toolkit.deprecated")}</span>
                </div>
                <div class="toolkit-pill is-deprecated">
                    <Icon name="simple-icons:cursor" class="toolkit-icon icon-cursor" />
                    <span class="toolkit-name">Cursor</span>
                    <span class="toolkit-dep">{t("toolkit.deprecated")}</span>
                </div>
            </div>
        </div>

        <!-- Token Usage -->
        <div class="toolkit-group">
            <h3 class="toolkit-label">
                {t("toolkit.tokenUsage")}
                <a href="https://aiusage.yizhe.me" target="_blank" rel="noopener noreferrer" class="toolkit-label-link">{t("toolkit.tokenUsageLink")}</a>
            </h3>
            <div class="ai-usage-embed">
                <iframe
                    class="stats-desktop"
                    src="https://aiusage.yizhe.me/embed?widget=stats-row1&items=0,1,2,3&transparent=true"
                    width="100%"
                    frameborder="0"
                    scrolling="no"
                ></iframe>
                <iframe
                    class="stats-mobile"
                    src="https://aiusage.yizhe.me/embed?widget=stats-row1&items=0,1&transparent=true"
                    width="100%"
                    frameborder="0"
                    scrolling="no"
                ></iframe>
                <iframe
                    class="cost-trend"
                    src="https://aiusage.yizhe.me/embed?widget=cost-trend&transparent=true"
                    width="100%"
                    frameborder="0"
                    scrolling="no"
                ></iframe>
            </div>
        </div>
    </div>
</section>

<script>
    // Auto-resize iframes via postMessage from embed
    window.addEventListener("message", (e) => {
        if (e.origin !== "https://aiusage.yizhe.me") return;
        const { widget, height } = e.data || {};
        if (!widget || !height) return;

        const iframes = document.querySelectorAll<HTMLIFrameElement>(".ai-usage-embed iframe");
        for (const iframe of iframes) {
            if (iframe.contentWindow === e.source) {
                iframe.style.height = `${height}px`;
                break;
            }
        }
    });
</script>

<style>
    .toolkit-groups {
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
    }

    .toolkit-label {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-text);
        margin-bottom: 1rem;
    }

    .toolkit-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-subtle);
        order: 2;
    }

    .toolkit-items {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    /* ── Pill ── */
    .toolkit-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 1rem;
        background: var(--panel-bg);
        border: 1px solid var(--border-subtle);
        border-radius: 0.7rem;
        transition:
            transform 280ms cubic-bezier(0.22, 0.68, 0, 1.1),
            box-shadow 280ms ease,
            border-color 280ms ease;
    }

    .toolkit-pill:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.07);
        border-color: rgba(37, 99, 235, 0.18);
    }

    :global(.dark) .toolkit-pill:hover {
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
        border-color: rgba(96, 165, 250, 0.18);
    }

    /* ── Icon ── */
    .toolkit-icon {
        width: 1.2rem;
        height: 1.2rem;
        flex-shrink: 0;
    }

    .icon-claude { color: #d97757; }
    .icon-openai { color: #1a1a1a; }
    :global(.dark) .icon-openai { color: #d4d4d8; }
    .icon-gemini { color: #4285f4; }
    .icon-kimi { color: #1a1a1a; }
    :global(.dark) .icon-kimi { color: #d4d4d8; }
    .icon-ghostty { color: #6b5b50; }
    :global(.dark) .icon-ghostty { color: #c4b5a8; }
    .icon-warp { color: #01a4ff; }
    .icon-codex { color: #1a1a1a; }
    :global(.dark) .icon-codex { color: #d4d4d8; }
    .icon-xcode { color: #147efb; }
    .icon-vscode { color: #007acc; }
    .icon-cursor { color: #555; }
    :global(.dark) .icon-cursor { color: #777; }

    /* ── Name ── */
    .toolkit-name {
        font-size: 0.85rem;
        font-weight: 550;
        color: #1e293b;
        white-space: nowrap;
    }

    :global(.dark) .toolkit-name {
        color: #e2e8f0;
    }

    /* ── Count badge (for x2) ── */
    .toolkit-count {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.08rem 0.35rem;
        border-radius: 0.3rem;
        line-height: 1.3;
    }

    .count-claude {
        color: #d97757;
        background: rgba(217, 119, 87, 0.1);
    }

    :global(.dark) .count-claude {
        background: rgba(217, 119, 87, 0.18);
    }

    /* ── Tag (VS Code note) ── */
    .toolkit-tag {
        font-size: 0.6rem;
        font-weight: 500;
        padding: 0.12rem 0.4rem;
        border-radius: 0.25rem;
        background: var(--panel-subtle);
        color: var(--muted-text);
        white-space: nowrap;
    }

    /* ── Deprecated ── */
    .is-deprecated {
        opacity: 0.5;
        border-style: dashed;
    }

    .is-deprecated .toolkit-name {
        text-decoration: line-through;
        text-decoration-thickness: 1.5px;
    }

    .is-deprecated:hover {
        transform: none;
        box-shadow: none;
        border-color: var(--border-subtle);
    }

    .toolkit-dep {
        font-size: 0.58rem;
        font-weight: 500;
        padding: 0.08rem 0.32rem;
        border-radius: 0.2rem;
        background: var(--panel-subtle);
        color: var(--muted-text);
        white-space: nowrap;
    }

    /* ── Responsive ── */
    @media (max-width: 480px) {
        .toolkit-items {
            gap: 0.5rem;
        }
        .toolkit-pill {
            padding: 0.5rem 0.8rem;
            gap: 0.45rem;
        }
        .toolkit-name {
            font-size: 0.8rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .toolkit-pill {
            transition: none !important;
        }
    }

    /* ── AI Usage Embed ── */
    .ai-usage-embed {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .ai-usage-embed iframe {
        border-radius: 0.75rem;
        display: block;
        overflow: hidden;
    }

    /* Fallback heights before postMessage auto-resize kicks in */
    .ai-usage-embed .stats-desktop,
    .ai-usage-embed .stats-mobile {
        height: 110px;
    }

    .ai-usage-embed .cost-trend {
        height: 410px;
    }

    .ai-usage-embed .stats-mobile {
        display: none;
    }

    @media (max-width: 768px) {
        .ai-usage-embed .stats-desktop {
            display: none;
        }
        .ai-usage-embed .stats-mobile {
            display: block;
        }
    }

    /* ── Label link ── */
    .toolkit-label-link {
        font-size: 0.58rem;
        font-weight: 500;
        color: var(--muted-text);
        text-decoration: none;
        letter-spacing: 0.02em;
        text-transform: none;
        transition: color 200ms ease;
        order: 3;
        margin-left: -0.25rem;
    }

    .toolkit-label-link:hover {
        color: #64748b;
    }

    :global(.dark) .toolkit-label-link:hover {
        color: #94a3b8;
    }
</style>

<script>
    window.addEventListener('message', function(e) {
        if (e.data && e.data.source === 'aiusage-embed' && e.data.height) {
            document.querySelectorAll('.ai-usage-embed iframe').forEach(function(f) {
                try {
                    var url = new URL(f.src, location.origin);
                    if (url.searchParams.get('widget') === e.data.widget) {
                        f.style.height = e.data.height + 'px';
                    }
                } catch(err) {}
            });
        }
    });
</script>
