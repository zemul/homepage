---
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="toolkit" class="py-16 px-4 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-10 text-center dark:text-white">{t("toolkit.title")}</h2>

    <div class="toolkit-groups">
        <!-- AI Subscriptions -->
        <div class="toolkit-group">
            <h3 class="toolkit-label">{t("toolkit.aiSubs")}</h3>
            <div class="toolkit-items">
                <div class="toolkit-pill">
                    <Icon name="simple-icons:claude" class="toolkit-icon icon-claude" />
                    <span class="toolkit-name">Claude Pro</span>
                    <span class="toolkit-count count-claude">&times;2</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:openai" class="toolkit-icon icon-openai" />
                    <span class="toolkit-name">ChatGPT Plus</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:googlegemini" class="toolkit-icon icon-gemini" />
                    <span class="toolkit-name">Google AI Pro</span>
                </div>
                <div class="toolkit-pill">
                    <svg class="toolkit-icon icon-doubao" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1.5 14.5c-2.49 0-4.5-2.01-4.5-4.5s2.01-4.5 4.5-4.5 4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm5-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" />
                    </svg>
                    <span class="toolkit-name">{lang === 'zh' ? '豆包' : 'Doubao'}</span>
                </div>
                <div class="toolkit-pill">
                    <svg class="toolkit-icon icon-kimi" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                    <span class="toolkit-name">Kimi</span>
                </div>
            </div>
        </div>

        <!-- Daily Tools -->
        <div class="toolkit-group">
            <h3 class="toolkit-label">{t("toolkit.dailyTools")}</h3>
            <div class="toolkit-items">
                <div class="toolkit-pill">
                    <svg class="toolkit-icon icon-ghostty" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C8.13 2 5 5.13 5 9v11l2-2 2 2 2-2 2 2 2-2 2 2V9c0-3.87-3.13-7-7-7zm-2.5 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z" />
                    </svg>
                    <span class="toolkit-name">Ghostty</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:warp" class="toolkit-icon icon-warp" />
                    <span class="toolkit-name">Warp</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:openai" class="toolkit-icon icon-codex" />
                    <span class="toolkit-name">Codex</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:xcode" class="toolkit-icon icon-xcode" />
                    <span class="toolkit-name">Xcode</span>
                </div>
                <div class="toolkit-pill">
                    <Icon name="simple-icons:visualstudiocode" class="toolkit-icon icon-vscode" />
                    <span class="toolkit-name">VS Code</span>
                    <span class="toolkit-tag">{t("toolkit.vscodeNote")}</span>
                </div>
                <div class="toolkit-pill is-deprecated">
                    <Icon name="simple-icons:cursor" class="toolkit-icon icon-cursor" />
                    <span class="toolkit-name">Cursor</span>
                    <span class="toolkit-dep">{t("toolkit.deprecated")}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .toolkit-groups {
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
    }

    .toolkit-label {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-text);
        margin-bottom: 1rem;
    }

    .toolkit-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-subtle);
    }

    .toolkit-items {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    /* ── Pill ── */
    .toolkit-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 1rem;
        background: var(--panel-bg);
        border: 1px solid var(--border-subtle);
        border-radius: 0.7rem;
        transition:
            transform 280ms cubic-bezier(0.22, 0.68, 0, 1.1),
            box-shadow 280ms ease,
            border-color 280ms ease;
    }

    .toolkit-pill:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.07);
        border-color: rgba(37, 99, 235, 0.18);
    }

    :global(.dark) .toolkit-pill:hover {
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
        border-color: rgba(96, 165, 250, 0.18);
    }

    /* ── Icon ── */
    .toolkit-icon {
        width: 1.2rem;
        height: 1.2rem;
        flex-shrink: 0;
    }

    .icon-claude { color: #d97757; }
    .icon-openai { color: #1a1a1a; }
    :global(.dark) .icon-openai { color: #d4d4d8; }
    .icon-gemini { color: #4285f4; }
    .icon-doubao { color: #4e6ef2; }
    .icon-kimi { color: #1a1a1a; }
    :global(.dark) .icon-kimi { color: #d4d4d8; }
    .icon-ghostty { color: #6b5b50; }
    :global(.dark) .icon-ghostty { color: #c4b5a8; }
    .icon-warp { color: #01a4ff; }
    .icon-codex { color: #1a1a1a; }
    :global(.dark) .icon-codex { color: #d4d4d8; }
    .icon-xcode { color: #147efb; }
    .icon-vscode { color: #007acc; }
    .icon-cursor { color: #555; }
    :global(.dark) .icon-cursor { color: #777; }

    /* ── Name ── */
    .toolkit-name {
        font-size: 0.85rem;
        font-weight: 550;
        color: #1e293b;
        white-space: nowrap;
    }

    :global(.dark) .toolkit-name {
        color: #e2e8f0;
    }

    /* ── Count badge (for x2) ── */
    .toolkit-count {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.08rem 0.35rem;
        border-radius: 0.3rem;
        line-height: 1.3;
    }

    .count-claude {
        color: #d97757;
        background: rgba(217, 119, 87, 0.1);
    }

    :global(.dark) .count-claude {
        background: rgba(217, 119, 87, 0.18);
    }

    /* ── Tag (VS Code note) ── */
    .toolkit-tag {
        font-size: 0.6rem;
        font-weight: 500;
        padding: 0.12rem 0.4rem;
        border-radius: 0.25rem;
        background: var(--panel-subtle);
        color: var(--muted-text);
        white-space: nowrap;
    }

    /* ── Deprecated ── */
    .is-deprecated {
        opacity: 0.5;
        border-style: dashed;
    }

    .is-deprecated .toolkit-name {
        text-decoration: line-through;
        text-decoration-thickness: 1.5px;
    }

    .is-deprecated:hover {
        transform: none;
        box-shadow: none;
        border-color: var(--border-subtle);
    }

    .toolkit-dep {
        font-size: 0.58rem;
        font-weight: 500;
        padding: 0.08rem 0.32rem;
        border-radius: 0.2rem;
        background: var(--panel-subtle);
        color: var(--muted-text);
        white-space: nowrap;
    }

    /* ── Responsive ── */
    @media (max-width: 480px) {
        .toolkit-items {
            gap: 0.5rem;
        }
        .toolkit-pill {
            padding: 0.5rem 0.8rem;
            gap: 0.45rem;
        }
        .toolkit-name {
            font-size: 0.8rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .toolkit-pill {
            transition: none !important;
        }
    }
</style>
