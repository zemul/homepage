---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="py-12 sm:py-16 px-5 text-center">
    <div class="max-w-2xl mx-auto">
        <div class="h-px bg-[var(--border-subtle)] mb-8"></div>
        <p class="text-sm text-[var(--muted-text)] leading-relaxed">
            {t("footer.copyright").replace('2025', String(year))}{t("footer.builtWith")}
        </p>
    </div>
</footer>
