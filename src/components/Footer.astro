---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="py-12 sm:py-16 px-5 text-center">
    <div class="max-w-2xl mx-auto">
        <div class="h-px bg-[var(--border-subtle)] mb-8"></div>
        <p class="flex flex-col items-center gap-1 sm:block text-sm text-[var(--muted-text)] leading-relaxed">
            <span>{t("footer.copyright").replace('2025', String(year))}</span>
            <span aria-hidden="true" class="hidden sm:inline mx-1.5">·</span>
            <span>{t("footer.builtWith")}</span>
        </p>
    </div>
</footer>
