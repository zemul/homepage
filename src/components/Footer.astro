---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const pageViewsApi = "https://views.yizhe.me";
const normalizedPathname =
    Astro.url.pathname.length > 1 && Astro.url.pathname.endsWith("/")
        ? Astro.url.pathname.slice(0, -1)
        : Astro.url.pathname;
const showTotalViews = ["/", "/en", "/zh"].includes(normalizedPathname);
---

<footer class="py-12 sm:py-16 px-5 text-center">
    <div class="max-w-2xl mx-auto">
        <div class="h-px bg-[var(--border-subtle)] mb-8"></div>
        <p class="text-sm text-[var(--muted-text)] leading-relaxed">
            <span>{t("footer.copyright").replace('2025', String(year))}</span>
            <span aria-hidden="true" class="mx-1.5">·</span>
            <span>{t("footer.builtWith")}</span>
            {showTotalViews && (
                <span
                    id="page-view-meta"
                    class="inline-flex items-center gap-2 whitespace-nowrap"
                    hidden
                >
                    <span aria-hidden="true">·</span>
                    <span id="page-view-count" data-label={t("footer.views")}></span>
                </span>
            )}
        </p>
    </div>
</footer>

<script define:vars={{ pageViewsApi, showTotalViews }}>
    const counterEl = document.getElementById("page-view-count");
    const counterMetaEl = document.getElementById("page-view-meta");
    const apiBase = typeof pageViewsApi === "string" ? pageViewsApi.replace(/\/+$/, "") : "";

    const normalizePathname = (pathname) => {
        if (!pathname) return "/";

        const sanitized = pathname.split("?")[0].split("#")[0].replace(/\/{2,}/g, "/");
        if (!sanitized) return "/";

        if (sanitized.length > 1 && sanitized.endsWith("/")) {
            return sanitized.slice(0, -1);
        }

        return sanitized;
    };

    const setCount = (count) => {
        if (!counterEl || !counterMetaEl) return;

        const label = counterEl.dataset.label || "Views";
        const formatted = new Intl.NumberFormat().format(count);
        const fullText = `${label} ${formatted}`;
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        counterMetaEl.hidden = false;

        if (prefersReducedMotion) {
            counterEl.textContent = fullText;
            return;
        }

        counterEl.textContent = "";

        let index = 0;
        const type = () => {
            if (!counterEl) return;

            counterEl.textContent = fullText.slice(0, index + 1);
            index += 1;

            if (index < fullText.length) {
                const currentChar = fullText[index - 1];
                const delay = currentChar === " " ? 24 : currentChar === "," ? 80 : 36;
                window.setTimeout(type, delay);
            }
        };

        window.setTimeout(type, 80);
    };

    const requestJson = async (url, init) => {
        const response = await fetch(url, init);
        if (!response.ok) {
            throw new Error(`Request failed with status ${response.status}`);
        }

        return response.json();
    };

    const syncPageViews = async () => {
        if (!apiBase) return;

        const pathname = normalizePathname(window.location.pathname);

        try {
            await requestJson(`${apiBase}/api/page/increment`, {
                method: "POST",
                body: new URLSearchParams({ pathname }),
                mode: "cors",
                credentials: "omit",
            });

            if (!showTotalViews || !counterEl || !counterMetaEl) {
                return;
            }

            const data = await requestJson(`${apiBase}/api/page/total`, {
                mode: "cors",
                credentials: "omit",
            });

            if (typeof data?.count !== "number") {
                throw new Error("Invalid page view payload");
            }

            setCount(data.count);
        } catch (error) {
            if (showTotalViews && counterMetaEl) counterMetaEl.hidden = true;
            console.error("Failed to sync page views:", error);
        }
    };

    if (document.readyState === "complete") {
        void syncPageViews();
    } else {
        window.addEventListener(
            "load",
            () => {
                void syncPageViews();
            },
            { once: true }
        );
    }
</script>
