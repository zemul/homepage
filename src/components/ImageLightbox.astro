<!-- Image Lightbox: click to zoom, scroll to scale, drag to pan, arrow keys to navigate -->
<div id="lightbox" class="lightbox-overlay" aria-hidden="true">
  <div class="lightbox-backdrop"></div>
  <img id="lightbox-img" class="lightbox-img" alt="" />
  <div class="lightbox-counter" id="lightbox-counter"></div>
</div>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 250ms ease;
    cursor: zoom-out;
  }
  .lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .lightbox-img {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    transform-origin: center center;
    transition: transform 200ms ease;
    user-select: none;
    -webkit-user-drag: none;
  }
  .lightbox-counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.1em;
    pointer-events: none;
  }
</style>

<script type="module" data-astro-rerun>
  window.__imageLightboxAbortController?.abort();
  const imageLightboxAbortController = new AbortController();
  window.__imageLightboxAbortController = imageLightboxAbortController;
  const imageLightboxSignal = imageLightboxAbortController.signal;

  document.addEventListener(
    'astro:before-swap',
    () => {
      document.body.style.overflow = '';
      imageLightboxAbortController.abort();
    },
    { once: true, signal: imageLightboxSignal }
  );

  const overlay = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img');
  const counter = document.getElementById('lightbox-counter');

  if (!overlay || !img || !counter) {
    imageLightboxAbortController.abort();
  }

  // Collect all prose images
  const allImages = Array.from(document.querySelectorAll('.prose img'));
  let currentIndex = 0;

  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let lastTranslateX = 0;
  let lastTranslateY = 0;

  function applyTransform() {
    img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
  }

  function resetState() {
    scale = 1;
    translateX = 0;
    translateY = 0;
    isDragging = false;
    img.style.transform = '';
    img.style.transition = 'transform 200ms ease';
  }

  function showImage(index) {
    if (index < 0 || index >= allImages.length) return;
    currentIndex = index;
    resetState();
    const source = allImages[index];
    img.src = source.currentSrc || source.src;
    img.alt = source.alt;
    counter.textContent = `${index + 1} / ${allImages.length}`;
  }

  function openLightbox(index) {
    showImage(index);
    overlay.classList.add('active');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    overlay.classList.remove('active');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Click on prose images to open
  allImages.forEach((image, i) => {
    image.style.cursor = 'zoom-in';
    image.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      openLightbox(i);
    }, { signal: imageLightboxSignal });
  });

  // Close on backdrop click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay || e.target === overlay.querySelector('.lightbox-backdrop')) {
      closeLightbox();
    } else if (e.target === img && scale <= 1 && !isDragging) {
      closeLightbox();
    }
  }, { signal: imageLightboxSignal });

  // Keyboard: Escape close, Left/Right navigate
  document.addEventListener('keydown', (e) => {
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && scale <= 1) showImage(currentIndex - 1);
    if (e.key === 'ArrowRight' && scale <= 1) showImage(currentIndex + 1);
  }, { signal: imageLightboxSignal });

  // Scroll to zoom — reduced sensitivity
  overlay.addEventListener('wheel', (e) => {
    e.preventDefault();
    img.style.transition = 'none';

    const delta = e.deltaY > 0 ? -0.06 : 0.06;
    const newScale = Math.min(Math.max(scale + delta, 0.5), 5);

    const rect = img.getBoundingClientRect();
    const cx = e.clientX - rect.left - rect.width / 2;
    const cy = e.clientY - rect.top - rect.height / 2;

    translateX -= cx * (newScale / scale - 1);
    translateY -= cy * (newScale / scale - 1);
    scale = newScale;

    applyTransform();
  }, { passive: false, signal: imageLightboxSignal });

  // Drag to pan
  img.addEventListener('mousedown', (e) => {
    if (scale <= 1) return;
    e.preventDefault();
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    lastTranslateX = translateX;
    lastTranslateY = translateY;
    img.style.transition = 'none';
    img.style.cursor = 'grabbing';
  }, { signal: imageLightboxSignal });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    translateX = lastTranslateX + (e.clientX - dragStartX);
    translateY = lastTranslateY + (e.clientY - dragStartY);
    applyTransform();
  }, { signal: imageLightboxSignal });

  document.addEventListener('mouseup', () => {
    if (isDragging) {
      isDragging = false;
      img.style.cursor = scale > 1 ? 'grab' : 'zoom-out';
    }
  }, { signal: imageLightboxSignal });

  // Touch: pinch zoom + drag
  let lastTouchDist = 0;
  let touchStartX = 0;
  let touchStartY = 0;

  img.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      lastTouchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    } else if (e.touches.length === 1 && scale > 1) {
      isDragging = true;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      lastTranslateX = translateX;
      lastTranslateY = translateY;
      img.style.transition = 'none';
    }
  }, { passive: true, signal: imageLightboxSignal });

  img.addEventListener('touchmove', (e) => {
    if (e.touches.length === 2) {
      e.preventDefault();
      const dist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      const ratio = dist / lastTouchDist;
      scale = Math.min(Math.max(scale * ratio, 0.5), 5);
      lastTouchDist = dist;
      img.style.transition = 'none';
      applyTransform();
    } else if (isDragging && e.touches.length === 1) {
      translateX = lastTranslateX + (e.touches[0].clientX - touchStartX);
      translateY = lastTranslateY + (e.touches[0].clientY - touchStartY);
      applyTransform();
    }
  }, { passive: false, signal: imageLightboxSignal });

  img.addEventListener('touchend', () => {
    isDragging = false;
    lastTouchDist = 0;
  }, { signal: imageLightboxSignal });
</script>
