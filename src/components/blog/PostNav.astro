---
import { useTranslations } from '../../i18n/utils';

interface NavPost {
  title: string;
  url: string;
}

interface Props {
  lang: 'en' | 'zh';
  /** The post published just after the current one (chronologically newer). */
  newerPost?: NavPost;
  /** The post published just before the current one (chronologically older). */
  olderPost?: NavPost;
  listUrl: string;
  currentUrl: string;
}

const { lang, newerPost, olderPost, listUrl, currentUrl } = Astro.props;
const t = useTranslations(lang);
---

<nav class="post-nav mt-16 sm:mt-20 pt-10 border-t border-[var(--border-subtle)]" aria-label="Post navigation">
  <!-- Left = newer (the post published after this one), right = older. -->
  {(newerPost || olderPost) && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-10">
      {newerPost ? (
        <a
          href={newerPost.url}
          class="post-nav-card scroll-top group"
          aria-label={`${t('blog.newerPost')}: ${newerPost.title}`}
        >
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--muted-text)] inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5"></path>
              <path d="m12 19-7-7 7-7"></path>
            </svg>
            {t('blog.newerPost')}
          </span>
          <span class="font-display block mt-2 text-[1.0625rem] sm:text-[1.125rem] text-[var(--text-primary)] group-hover:text-[var(--accent-hover)] transition-colors duration-200" style="font-weight: 500; letter-spacing: -0.01em; line-height: 1.35;">
            {newerPost.title}
          </span>
        </a>
      ) : <span class="hidden sm:block" />}

      {olderPost ? (
        <a
          href={olderPost.url}
          class="post-nav-card post-nav-card--end scroll-top group"
          aria-label={`${t('blog.olderPost')}: ${olderPost.title}`}
        >
          <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--muted-text)] inline-flex items-center gap-1.5">
            {t('blog.olderPost')}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
          <span class="font-display block mt-2 text-[1.0625rem] sm:text-[1.125rem] text-[var(--text-primary)] group-hover:text-[var(--accent-hover)] transition-colors duration-200" style="font-weight: 500; letter-spacing: -0.01em; line-height: 1.35;">
            {olderPost.title}
          </span>
        </a>
      ) : <span class="hidden sm:block" />}
    </div>
  )}

  <!-- Back to list -->
  <div class="flex justify-center">
    <a href={listUrl} class="back-to-list btn-secondary" data-current-url={currentUrl}>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7" rx="1"></rect>
        <rect x="14" y="3" width="7" height="7" rx="1"></rect>
        <rect x="3" y="14" width="7" height="7" rx="1"></rect>
        <rect x="14" y="14" width="7" height="7" rx="1"></rect>
      </svg>
      {t('blog.backToList')}
    </a>
  </div>
</nav>

<style>
  .post-nav-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background-color: var(--panel-subtle);
    transition: border-color 200ms ease, background-color 200ms ease, transform 200ms ease;
  }

  .post-nav-card:hover {
    border-color: var(--accent);
    background-color: var(--page-bg);
  }

  .post-nav-card--end {
    text-align: right;
  }

  @media (max-width: 640px) {
    .post-nav-card--end {
      text-align: left;
    }
  }
</style>

<script>
  // Scroll to top for prev/next links
  document.querySelectorAll<HTMLAnchorElement>('.scroll-top').forEach(link => {
    link.addEventListener('click', () => {
      sessionStorage.removeItem('blog-scroll-target');
    });
  });

  // Back to list: save current post URL for scroll restoration
  document.querySelectorAll<HTMLAnchorElement>('.back-to-list').forEach(link => {
    link.addEventListener('click', () => {
      const currentUrl = link.dataset.currentUrl;
      if (currentUrl) {
        sessionStorage.setItem('blog-scroll-target', currentUrl);
      }
    });
  });
</script>
