---
import { useTranslations } from '../../i18n/utils';

interface Props {
  post: {
    data: {
      title: string;
      date: string;
      description: string;
      lang: 'en' | 'zh';
      tags?: string[];
    };
  };
  body: string;
  lang: 'en' | 'zh';
  switchUrl: string;
}

const { post, body, lang, switchUrl } = Astro.props;
const t = useTranslations(lang);

function estimateReadTime(text: string, lang: 'en' | 'zh'): number {
  if (lang === 'zh') {
    const chars = text.replace(/\s/g, '').length;
    return Math.max(1, Math.round(chars / 400));
  }
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

const readTime = estimateReadTime(body, lang);
const readTimeText = t('blog.readTime').replace('{n}', String(readTime));
const backUrl = lang === 'zh' ? '/zh/blog' : '/blog';
const tags = post.data.tags ?? [];
---

<header class="mb-10 sm:mb-12">
  <!-- Back link (visible on mobile, hidden on desktop where TOC has it) -->
  <a
    href={backUrl}
    class="inline-flex items-center gap-1.5 text-sm text-[var(--muted-text)] hover:text-gray-900 dark:hover:text-gray-100 transition-colors duration-150 mb-6"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M9 11L5 7l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    {t('blog.backToList')}
  </a>

  <!-- Title first -->
  <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight text-balance">
    {post.data.title}
  </h1>

  <!-- Meta row: date · read time · tags · lang switch -->
  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mt-4 text-sm text-[var(--muted-text)]">
    <time class="tabular-nums">{post.data.date}</time>
    <span class="text-[var(--border-subtle)]">&middot;</span>
    <span>{readTimeText}</span>
    {tags.length > 0 && (
      <>
        <span class="text-[var(--border-subtle)]">&middot;</span>
        {tags.map((tag: string) => (
          <span class="text-xs px-2 py-0.5 rounded-md bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400">
            {tag}
          </span>
        ))}
      </>
    )}
    <span class="ml-auto">
      <a
        href={switchUrl}
        class="text-xs text-[var(--muted-text)] hover:text-blue-500 transition-colors duration-150 border border-[var(--border-subtle)] rounded-full px-2.5 py-0.5 hover:border-blue-400"
      >
        {t('blog.switchLang')}
      </a>
    </span>
  </div>
</header>
