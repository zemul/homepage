---
import { useTranslations } from '../../i18n/utils';

interface Props {
  post: {
    data: {
      title: string;
      date: string;
      description: string;
      lang: 'en' | 'zh';
      tags?: string[];
    };
  };
  body: string;
  lang: 'en' | 'zh';
  switchUrl: string;
  listUrl: string;
  currentUrl: string;
}

const { post, body, lang, switchUrl, listUrl, currentUrl } = Astro.props;
const t = useTranslations(lang);

function estimateReadTime(text: string, lang: 'en' | 'zh'): number {
  if (lang === 'zh') {
    const chars = text.replace(/\s/g, '').length;
    return Math.max(1, Math.round(chars / 400));
  }
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

function formatDate(dateStr: string, lang: 'en' | 'zh') {
  const [year, month] = dateStr.split('-');
  if (lang === 'zh') {
    return `${year} 年 ${parseInt(month)} 月`;
  }
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  return `${monthNames[parseInt(month) - 1]} ${year}`;
}

const readTime = estimateReadTime(body, lang);
const readTimeText = t('blog.readTime').replace('{n}', String(readTime));
const tags = post.data.tags ?? [];
---

<header class="mb-12 sm:mb-16" style="animation: fadeIn 500ms ease-out both;">
  <!-- Back to list (top) -->
  <a
    href={listUrl}
    class="back-to-list inline-flex items-center gap-1.5 font-mono text-[11px] tracking-[0.18em] uppercase text-[var(--muted-text)] hover:text-[var(--accent)] transition-colors duration-200 mb-8 sm:mb-10"
    data-current-url={currentUrl}
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M19 12H5"></path>
      <path d="m12 19-7-7 7-7"></path>
    </svg>
    {t('blog.backToList')}
  </a>

  <!-- Eyebrow: date · read time -->
  <div class="flex items-center gap-3 mb-5 sm:mb-6">
    <time class="font-mono text-[11px] tracking-[0.18em] uppercase text-[var(--muted-text)]" style="font-feature-settings: 'tnum';">
      {formatDate(post.data.date, lang)}
    </time>
    <span class="w-1 h-1 rounded-full bg-[var(--border-subtle)]" aria-hidden="true"></span>
    <span class="font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--muted-text)]">{readTimeText}</span>
  </div>

  <!-- Title -->
  <h1
    class="font-display text-[2.25rem] sm:text-[2.75rem] md:text-[3rem] leading-[1.1] text-[var(--text-primary)] text-balance"
    style="font-weight: 500; letter-spacing: -0.025em;"
  >
    {post.data.title}
  </h1>

  <!-- Description -->
  {post.data.description && (
    <p class="blog-lead mt-5 sm:mt-6 max-w-2xl text-base sm:text-lg text-[var(--text-secondary)]" style="line-height: 1.6;">
      {post.data.description}
    </p>
  )}

  <!-- Tags + lang switch -->
  <div class="flex flex-wrap items-center gap-2 mt-7 sm:mt-8">
    {tags.map((tag: string) => (
      <span class="badge-pill">{tag}</span>
    ))}
    <span class="flex-1"></span>
    <a href={switchUrl} class="btn-secondary ml-auto">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
      </svg>
      {t('blog.switchLang')}
    </a>
  </div>

  <!-- Divider -->
  <div class="mt-10 sm:mt-12 h-px bg-[var(--border-subtle)]"></div>
</header>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
