---
import { useTranslations } from '../../i18n/utils';

interface Props {
  post: {
    data: {
      title: string;
      date: string;
      description: string;
      lang: 'en' | 'zh';
      tags?: string[];
    };
  };
  body: string;
  lang: 'en' | 'zh';
  switchUrl: string;
}

const { post, body, lang, switchUrl } = Astro.props;
const t = useTranslations(lang);

function estimateReadTime(text: string, lang: 'en' | 'zh'): number {
  if (lang === 'zh') {
    const chars = text.replace(/\s/g, '').length;
    return Math.max(1, Math.round(chars / 400));
  }
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

function formatDate(dateStr: string, lang: 'en' | 'zh') {
  const [year, month] = dateStr.split('-');
  if (lang === 'zh') {
    return `${year} 年 ${parseInt(month)} 月`;
  }
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  return `${monthNames[parseInt(month) - 1]} ${year}`;
}

const readTime = estimateReadTime(body, lang);
const readTimeText = t('blog.readTime').replace('{n}', String(readTime));
const tags = post.data.tags ?? [];
---

<header class="mb-12 sm:mb-16" style="animation: fadeIn 500ms ease-out both;">
  <!-- Title first -->
  <h1 class="font-display text-3xl sm:text-4xl md:text-[2.75rem] font-bold leading-[1.15] text-[var(--text-primary)] text-balance" style="letter-spacing: -0.03em;">
    {post.data.title}
  </h1>

  <!-- Tags + lang switch -->
  <div class="flex flex-wrap items-center gap-2 mt-5 sm:mt-6">
    {tags.map((tag: string) => (
      <span class="font-mono text-[10px] tracking-wider uppercase text-[var(--muted-text)] px-2 py-1 rounded-md bg-[var(--panel-subtle)] border border-[var(--border-subtle)]">
        {tag}
      </span>
    ))}
    {tags.length > 0 && <span class="flex-1"></span>}
    <a
      href={switchUrl}
      class="font-mono text-[11px] tracking-wide text-[var(--muted-text)] hover:text-[var(--accent)] transition-colors duration-200 border border-[var(--border-subtle)] hover:border-[var(--accent)] rounded-full px-3 py-1 ml-auto"
    >
      {t('blog.switchLang')}
    </a>
  </div>

  <!-- Meta line: date · read time -->
  <div class="flex items-center gap-3 mt-4">
    <time class="font-mono text-xs tracking-wide uppercase text-[var(--muted-text)]" style="font-feature-settings: 'tnum';">
      {formatDate(post.data.date, lang)}
    </time>
    <span class="w-1 h-1 rounded-full bg-[var(--border-subtle)]" aria-hidden="true"></span>
    <span class="font-mono text-xs tracking-wide text-[var(--muted-text)]">{readTimeText}</span>
  </div>

  <!-- Divider -->
  <div class="mt-8 sm:mt-10 h-px bg-[var(--border-subtle)]"></div>
</header>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
