---
import ThemeToggle from '../ThemeToggle.astro';
import LanguagePicker from '../LanguagePicker.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname;

const homeUrl = lang === 'zh' ? '/zh/' : '/';
const blogUrl = lang === 'zh' ? '/zh/blog' : '/blog';
const aboutUrl = lang === 'zh' ? '/zh/about' : '/about';

const isHomeActive =
  pathname === '/' || pathname === '/zh' || pathname === '/zh/';
const isBlogActive =
  pathname === '/blog' ||
  pathname.startsWith('/blog/') ||
  pathname === '/zh/blog' ||
  pathname.startsWith('/zh/blog/');
const isAboutActive =
  pathname === '/about' ||
  pathname === '/about/' ||
  pathname === '/zh/about' ||
  pathname === '/zh/about/' ||
  pathname === '/en/about' ||
  pathname === '/en/about/';

// Split label into per-char spans so we can justify both ends across
// a fixed slot — same geometry regardless of language or active state.
const splitChars = (s: string) => Array.from(s);
const homeChars = splitChars(t('nav.home'));
const blogChars = splitChars(t('nav.blog'));
const aboutChars = splitChars(t('nav.about'));
---

<header class="site-topnav" data-topnav>
  <div class="site-topnav-inner">
    <a href={homeUrl} class="site-topnav-avatar" aria-label={t('nav.home')}>
      <img
        src="/bg.webp"
        alt=""
        width="80"
        height="80"
        loading="eager"
        decoding="async"
        draggable="false"
        class="site-topnav-avatar-bg"
        transition:persist="site-topnav-avatar-bg"
      />
      <img
        src="/person.webp"
        alt=""
        width="80"
        height="80"
        loading="eager"
        decoding="async"
        draggable="false"
        class="site-topnav-avatar-person"
        transition:persist="site-topnav-avatar-person"
      />
    </a>
    <nav class="site-topnav-links" aria-label="Primary" data-nav-list>
      <a href={homeUrl} class:list={["site-topnav-link", isHomeActive && "is-active"]}>
        <span class="site-topnav-label">
          {homeChars.map((c) => <span class="site-topnav-ch">{c}</span>)}
        </span>
      </a>
      <a
        href={blogUrl}
        class:list={["site-topnav-link", isBlogActive && "is-active"]}
        data-blog-link
      >
        <span class="site-topnav-label">
          {blogChars.map((c) => <span class="site-topnav-ch">{c}</span>)}
        </span>
      </a>
      <a href={aboutUrl} class:list={["site-topnav-link", isAboutActive && "is-active"]}>
        <span class="site-topnav-label">
          {aboutChars.map((c) => <span class="site-topnav-ch">{c}</span>)}
        </span>
      </a>
      <svg
        class="site-topnav-indicator"
        data-nav-indicator
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <defs>
          <linearGradient id="nav-ind-fade-active" data-fade-active gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="0" y2="0">
            <stop offset="0" stop-color="white" stop-opacity="0"/>
            <stop offset="0.18" stop-color="white" stop-opacity="1"/>
            <stop offset="0.82" stop-color="white" stop-opacity="1"/>
            <stop offset="1" stop-color="white" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="nav-ind-fade-hover" data-fade-hover gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="0" y2="0">
            <stop offset="0" stop-color="white" stop-opacity="0"/>
            <stop offset="0.18" stop-color="white" stop-opacity="1"/>
            <stop offset="0.82" stop-color="white" stop-opacity="1"/>
            <stop offset="1" stop-color="white" stop-opacity="0"/>
          </linearGradient>
          <mask id="nav-ind-mask-active" maskUnits="userSpaceOnUse">
            <rect data-mask-active fill="url(#nav-ind-fade-active)" x="0" y="0" width="0" height="100%"/>
          </mask>
          <mask id="nav-ind-mask-hover" maskUnits="userSpaceOnUse">
            <rect data-mask-hover fill="url(#nav-ind-fade-hover)" x="0" y="0" width="0" height="100%"/>
          </mask>
        </defs>
        <g class="site-topnav-indicator-active" mask="url(#nav-ind-mask-active)">
          <path data-nav-path-active fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
        </g>
        <g class="site-topnav-indicator-hover" mask="url(#nav-ind-mask-hover)">
          <path data-nav-path-hover fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
        </g>
      </svg>
    </nav>

    <div class="site-topnav-right">
      <div class="site-topnav-controls">
        <ThemeToggle />
        <LanguagePicker />
      </div>
    </div>
  </div>
</header>

<script type="module" data-astro-rerun>
  window.__topNavAbortController?.abort();
  const topNavAbortController = new AbortController();
  window.__topNavAbortController = topNavAbortController;
  const topNavSignal = topNavAbortController.signal;

  document.addEventListener(
    'astro:before-swap',
    () => topNavAbortController.abort(),
    { once: true, signal: topNavSignal },
  );

  // Compact (pill) mode on scroll — desktop only.
  // Mobile keeps the original "hide on scroll" behaviour for taller tap area.
  const nav = document.querySelector('[data-topnav]');
  const inner = nav?.querySelector('.site-topnav-inner') ?? null;

  if (nav) {
    const COMPACT_ENTER = 72;
    const COMPACT_EXIT  = 4;
    const HIDE_DELTA = 2;
    const SHOW_DELTA = 6;
    const TOP_ZONE   = 4;

    const desktopMQ = window.matchMedia('(min-width: 640px)');
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;

      nav.classList.remove('is-compact');
      nav.classList.remove('is-hidden');

      nav.classList.toggle('is-scrolled', y > TOP_ZONE);

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true, signal: topNavSignal }
    );

    // Reset state when crossing the desktop/mobile boundary.
    desktopMQ.addEventListener('change', () => {
      if (!desktopMQ.matches) {
        nav.classList.remove('is-compact');
      } else {
        nav.classList.remove('is-hidden');
      }
      update();
    }, { signal: topNavSignal });

    nav.addEventListener('focusin', () => nav.classList.remove('is-hidden'), { signal: topNavSignal });
    update();

    if (inner) {
      const resetGlassLight = () => {
        inner.style.setProperty('--glass-x', '18%');
        inner.style.setProperty('--glass-y', '0%');
        inner.style.setProperty('--glass-sheen', '0.72');
      };

      inner.addEventListener('pointermove', (event) => {
        const rect = inner.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        inner.style.setProperty('--glass-x', `${Math.max(0, Math.min(100, x)).toFixed(1)}%`);
        inner.style.setProperty('--glass-y', `${Math.max(0, Math.min(100, y)).toFixed(1)}%`);
        inner.style.setProperty('--glass-sheen', '0.9');
      }, { passive: true, signal: topNavSignal });

      inner.addEventListener('pointerleave', resetGlassLight, { signal: topNavSignal });
      topNavSignal.addEventListener('abort', resetGlassLight, { once: true });
    }
  }

  // Scroll-restoration handoff for the Blog link.
  const ARTICLE_RE = /^\/(?:zh\/)?blog\/[^/]+\/[^/]+\/?$/;
  document.querySelectorAll('[data-blog-link]').forEach((link) => {
    link.addEventListener('click', () => {
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      if (ARTICLE_RE.test(path)) {
        sessionStorage.setItem('blog-scroll-target', path);
      }
    }, { signal: topNavSignal });
  });

  // Two independent squiggle tracks:
  //   - "active" track: anchored to the truly selected link, never moves on hover.
  //   - "hover"  track: a faint preview that slides out from the active one and
  //                     tracks pointer/focus across other links; fades out on leave.
  // Each end (left / right) of each track has its own spring so the wave
  // stretches naturally as it crosses link boundaries.
  const navList = document.querySelector('[data-nav-list]');
  const indicator = document.querySelector('[data-nav-indicator]');
  const activePathEl = document.querySelector('[data-nav-path-active]');
  const hoverPathEl  = document.querySelector('[data-nav-path-hover]');
  const activeMaskRect = document.querySelector('[data-mask-active]');
  const hoverMaskRect  = document.querySelector('[data-mask-hover]');
  const activeFade = document.querySelector('[data-fade-active]');
  const hoverFade  = document.querySelector('[data-fade-hover]');

  if (
    navList && indicator &&
    activePathEl && hoverPathEl &&
    activeMaskRect && hoverMaskRect &&
    activeFade && hoverFade
  ) {
    const GAP = 6;
    const AMP = 1.25;
    const PERIOD = 9;
    const H = 8;
    const MID = H / 2;
    const EXT = 6;     // px — extend wave slightly past the text on each side
    const FEATHER = 10; // px — how far each end fades out

    const mkSpring = () => ({ x: 0, v: 0, target: 0 });
    const activeTrack = {
      left: mkSpring(), right: mkSpring(),
      raf: 0, ready: false,
      pathEl: activePathEl,
      maskRect: activeMaskRect,
      fade: activeFade,
      seed: Math.random() * 1000,
    };
    const hoverTrack = {
      left: mkSpring(), right: mkSpring(),
      raf: 0, ready: false,
      pathEl: hoverPathEl,
      maskRect: hoverMaskRect,
      fade: hoverFade,
      seed: Math.random() * 1000 + 500,
    };

    const STIFF_HEAD = 220;
    const STIFF_TAIL = 150;
    const DAMP_HEAD  = 22;
    const DAMP_TAIL  = 19;

    // Deterministic pseudo-random: stable for a given (seed, index) so the
    // wave shape doesn't shimmer between animation frames.
    const noise = (seed, i) => {
      const x = Math.sin(seed * 12.9898 + i * 78.233) * 43758.5453;
      return x - Math.floor(x); // 0..1
    };

    const buildPath = (a, b, stretch, seed) => {
      const w = Math.max(2, b - a);
      const halves = Math.max(2, Math.round(w / PERIOD));
      const step = w / halves;
      const baseAmp = AMP * (1 + Math.min(1.2, stretch * 0.012));

      // Anchor Y for every half-wave boundary, including the two endpoints,
      // is offset by noise so the wave doesn't always "start at mid going down".
      const anchorY = [];
      for (let i = 0; i <= halves; i++) {
        // Boundary drift: roomy at the ends so the start/finish look organic;
        // the masked fade hides any slight Y mismatch from the baseline.
        const drift = (noise(seed, i * 2 + 11) - 0.5) * 1.4;
        anchorY.push(MID + drift);
      }

      // Random initial direction so half the time the first bump goes up.
      const startDir = noise(seed, 17) < 0.5 ? -1 : 1;

      let d = `M ${a} ${anchorY[0].toFixed(2)}`;
      for (let i = 0; i < halves; i++) {
        // Amplitude per half wave (50%–145%) — more variance, smaller base.
        const ampJitter = 0.5 + noise(seed, i * 7 + 3) * 0.95;
        const amp = baseAmp * ampJitter;
        const dir = (i % 2 === 0 ? 1 : -1) * startDir;

        // Control-point X shifted off-center by ±30% of step
        const xMid = a + step * i + step / 2;
        const xShift = (noise(seed, i * 5 + 1) - 0.5) * step * 0.6;
        const x1 = xMid + xShift;

        // Control-point Y = local midline (between the two anchors) + bump
        const localMid = (anchorY[i] + anchorY[i + 1]) / 2;
        const yJit = (noise(seed, i * 3 + 9) - 0.5) * 0.7;
        const y1 = localMid + dir * amp + yJit;

        const x2 = a + step * (i + 1);
        const y2 = anchorY[i + 1];

        d += ` Q ${x1.toFixed(2)} ${y1.toFixed(2)} ${x2.toFixed(2)} ${y2.toFixed(2)}`;
      }
      return d;
    };

    const measure = (target) => {
      const label = target.querySelector('.site-topnav-label') ?? target;
      const navRect = navList.getBoundingClientRect();
      const r = label.getBoundingClientRect();
      return {
        left: r.left - navRect.left - EXT,
        right: r.right - navRect.left + EXT,
        top: r.bottom - navRect.top + GAP,
        navWidth: navRect.width,
      };
    };

    const currentActive = () =>
      navList.querySelector('.site-topnav-link.is-active');

    const setSvgFrame = (navWidth, top) => {
      indicator.setAttribute('viewBox', `0 0 ${navWidth} ${H}`);
      indicator.style.setProperty('--nav-ind-top', `${top}px`);
      indicator.style.setProperty('--nav-ind-width', `${navWidth}px`);
    };

    // Sync the mask rect + the linear-gradient fade endpoints so each track's
    // wave fades out softly at both ends instead of being chopped.
    const syncMask = (track) => {
      const a = track.left.x;
      const b = track.right.x;
      const w = Math.max(0, b - a);
      // Mask rect spans the full path including a small overshoot, but fade
      // gradient is locked to the actual path region.
      track.maskRect.setAttribute('x', `${a - FEATHER}`);
      track.maskRect.setAttribute('width', `${w + FEATHER * 2}`);
      track.fade.setAttribute('x1', `${a - FEATHER}`);
      track.fade.setAttribute('x2', `${b + FEATHER}`);
    };

    const stepSpring = (s, stiff, damp) => {
      const dt = 1 / 60;
      const f = -stiff * (s.x - s.target) - damp * s.v;
      s.v += f * dt;
      s.x += s.v * dt;
    };

    const tickTrack = (track) => {
      const leftLeading  = track.left.target  < track.left.x;
      const rightLeading = track.right.target > track.right.x;

      stepSpring(
        track.left,
        leftLeading ? STIFF_HEAD : STIFF_TAIL,
        leftLeading ? DAMP_HEAD : DAMP_TAIL,
      );
      stepSpring(
        track.right,
        rightLeading ? STIFF_HEAD : STIFF_TAIL,
        rightLeading ? DAMP_HEAD : DAMP_TAIL,
      );

      const restWidth = (track.right.target - track.left.target);
      const liveWidth = (track.right.x - track.left.x);
      const stretch = Math.max(0, liveWidth - restWidth);

      track.pathEl.setAttribute('d', buildPath(track.left.x, track.right.x, stretch, track.seed));
      syncMask(track);

      const settled =
        Math.abs(track.left.x - track.left.target) < 0.1 &&
        Math.abs(track.right.x - track.right.target) < 0.1 &&
        Math.abs(track.left.v) < 0.1 &&
        Math.abs(track.right.v) < 0.1;

      if (!settled) {
        track.raf = requestAnimationFrame(() => tickTrack(track));
      } else {
        track.left.x = track.left.target;
        track.right.x = track.right.target;
        track.pathEl.setAttribute('d', buildPath(track.left.x, track.right.x, 0, track.seed));
        syncMask(track);
        track.raf = 0;
      }
    };

    const placeTrack = (track, target, animate) => {
      if (!target) return false;
      const { left, right, top, navWidth } = measure(target);
      setSvgFrame(navWidth, top);

      track.left.target = left;
      track.right.target = right;

      if (!track.ready || !animate) {
        track.left.x = left; track.right.x = right;
        track.left.v = 0;    track.right.v = 0;
        track.pathEl.setAttribute('d', buildPath(left, right, 0, track.seed));
        syncMask(track);
        track.ready = true;
      } else if (!track.raf) {
        // Each hop gets a fresh seed so the new wave looks naturally different.
        track.seed = Math.random() * 1000;
        track.raf = requestAnimationFrame(() => tickTrack(track));
      }
      return true;
    };

    // ── Initial placement: active track lands on the active link silently;
    //    hover track starts at the same spot but is invisible until hover.
    const initialActive = currentActive();
    if (initialActive) {
      placeTrack(activeTrack, initialActive, false);
      placeTrack(hoverTrack, initialActive, false);
      indicator.classList.add('is-visible');
    }

    // ── Hover behaviour: only the hover track moves.
    const showHoverAt = (link) => {
      placeTrack(hoverTrack, link, true);
      indicator.classList.add('is-hovering');
    };
    const hideHover = () => {
      // Fade out, snap the hover track back to the active link's geometry
      // so the next hover starts from the right place.
      const activeLink = currentActive();
      indicator.classList.remove('is-hovering');
      if (activeLink) {
        // Snap silently after the fade-out — no animation visible.
        placeTrack(hoverTrack, activeLink, false);
      }
    };

    const links = navList.querySelectorAll('.site-topnav-link');
    links.forEach((link) => {
      link.addEventListener('pointerenter', () => {
        if (!link.classList.contains('is-active')) showHoverAt(link);
        else hideHover();
      }, { signal: topNavSignal });
      link.addEventListener('focus', () => {
        if (!link.classList.contains('is-active')) showHoverAt(link);
        else hideHover();
      }, { signal: topNavSignal });
    });
    navList.addEventListener('pointerleave', hideHover, { signal: topNavSignal });
    navList.addEventListener('focusout', (e) => {
      const next = e.relatedTarget;
      if (!next || !(next instanceof Node) || !navList.contains(next)) hideHover();
    }, { signal: topNavSignal });

    // ── Re-align both tracks on resize / font load.
    const realign = () => {
      const a = currentActive();
      if (!a) return;
      placeTrack(activeTrack, a, false);
      if (!indicator.classList.contains('is-hovering')) {
        placeTrack(hoverTrack, a, false);
      }
    };
    window.addEventListener('resize', realign, { passive: true, signal: topNavSignal });
    if (document.fonts?.ready) {
      document.fonts.ready.then(() => {
        if (!topNavSignal.aborted) realign();
      });
    }

    // ── Keep indicator aligned while the nav inner is animating between
    // full bar and compact pill (width transition is ~360ms).
    const innerEl = navList.closest('.site-topnav-inner');
    if (innerEl) {
      let realignRaf = 0;
      const startRealignLoop = () => {
        if (realignRaf) return;
        const loop = () => {
          realign();
          realignRaf = requestAnimationFrame(loop);
        };
        realignRaf = requestAnimationFrame(loop);
      };
      const stopRealignLoop = () => {
        if (realignRaf) {
          cancelAnimationFrame(realignRaf);
          realignRaf = 0;
        }
        realign();
      };
      innerEl.addEventListener('transitionrun', (e) => {
        if (e.propertyName === 'width' || e.propertyName === 'padding-left') startRealignLoop();
      }, { signal: topNavSignal });
      innerEl.addEventListener('transitionend', (e) => {
        if (e.propertyName === 'width' || e.propertyName === 'padding-left') stopRealignLoop();
      }, { signal: topNavSignal });
      innerEl.addEventListener('transitioncancel', stopRealignLoop, { signal: topNavSignal });
      topNavSignal.addEventListener('abort', stopRealignLoop, { once: true });
    }

    topNavSignal.addEventListener(
      'abort',
      () => {
        if (activeTrack.raf) cancelAnimationFrame(activeTrack.raf);
        if (hoverTrack.raf) cancelAnimationFrame(hoverTrack.raf);
      },
      { once: true },
    );
  }
</script>
