---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  lang: 'en' | 'zh';
}

const { headings, lang } = Astro.props;
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
const tocLabel = lang === 'zh' ? '目录' : 'On this page';
---

<aside class="toc-sidebar">
  {tocItems.length > 0 && (
    <nav class="toc-nav" aria-label={tocLabel}>
      <p class="toc-title">{tocLabel}</p>
      <ul class="toc-list">
        {tocItems.map((item) => (
          <li>
            <a
              href={`#${item.slug}`}
              class:list={[
                'toc-link',
                { 'toc-h3': item.depth === 3 }
              ]}
              data-slug={item.slug}
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}
</aside>

<script>
  function initToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (!links.length) return;

    const slugs = Array.from(links).map(l => l.dataset.slug!);
    const headingEls = slugs
      .map(s => document.getElementById(s))
      .filter(Boolean) as HTMLElement[];

    if (!headingEls.length) return;

    let current = slugs[0];

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            current = entry.target.id;
            break;
          }
        }
        links.forEach(link => {
          link.classList.toggle('toc-active', link.dataset.slug === current);
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  }

  initToc();
</script>

<style>
  .toc-sidebar {
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .toc-sidebar::-webkit-scrollbar {
    display: none;
  }

  .toc-title {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 0.75rem;
    padding-left: 1rem;
  }

  .toc-nav {
    border-left: 1px solid var(--border-subtle);
    padding-left: 0;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc-link {
    display: block;
    padding: 0.2rem 0 0.2rem 1rem;
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--muted-text);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .toc-link:hover {
    color: var(--text-secondary);
  }

  .toc-link.toc-active {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  .toc-h3 {
    padding-left: 1.75rem;
    font-size: 0.7rem;
  }
</style>
