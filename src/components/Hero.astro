---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 px-5 md:px-8 max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-12">
    <!-- Interactive Avatar Module -->
    <div id="avatar-container" class="relative w-52 h-52 rounded-full overflow-hidden shrink-0 shadow-2xl cursor-pointer group border-4 border-white/50 dark:border-[rgba(36,43,53,0.6)]">
        <!-- Static Background -->
        <div class="absolute inset-0 bg-[url('/bg.png')] bg-cover bg-center transition-transform duration-700 group-hover:scale-105"></div>

        <!-- Dynamic Foreground (Person) -->
        <div id="avatar-person" class="absolute inset-0 bg-[url('/person.png')] bg-cover bg-center transition-transform duration-300 ease-out origin-bottom" style="transform: scale(0.82) translate(0, 4px);">
        </div>

        <!-- Inner Shadow/Highlight for depth -->
        <div class="absolute inset-0 rounded-full shadow-[inset_0_0_20px_rgba(0,0,0,0.2)] pointer-events-none"></div>
    </div>

    <!-- Text Content -->
    <div class="text-left flex-1 w-full flex flex-col items-center md:items-start text-center md:text-left">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-violet-600 leading-tight whitespace-nowrap">
            <span id="typewriter-text" data-text={t("hero.title")}></span><span class="typewriter-cursor">|</span>
        </h1>
        <div class="flex flex-wrap justify-center md:justify-start gap-2 mb-6">
            {
                t("hero.subtitle")
                    .split(" · ")
                    .map((tag) => (
                        <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-50/50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 text-sm font-medium border border-blue-100 dark:border-blue-800/30 shadow-sm whitespace-nowrap">
                            {tag}
                        </div>
                    ))
            }
        </div>
        <p class="text-lg text-[var(--muted-text)] mb-6 max-w-2xl">
            {t("hero.desc")}
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gray-100 dark:bg-[var(--panel-bg)] text-gray-600 dark:text-gray-200 text-sm font-medium shadow-sm">
            {t("hero.location")}
        </div>
    </div>
</section>

<style>
    @keyframes blink {
        0%,
        100% {
            visibility: visible;
        }
        50% {
            visibility: hidden;
        }
    }
    .typewriter-cursor {
        animation: blink 1s step-end infinite;
        margin-left: 2px;
        font-weight: 400; /* Regular weight to ensure visibility */
    }
</style>

<script>
    const container = document.getElementById("avatar-container");
    const person = document.getElementById("avatar-person");

    if (container && person) {
        container.addEventListener("mousemove", (e) => {
            const rect = container.getBoundingClientRect();
            const x = e.clientX - rect.left; // x position within the element.
            const y = e.clientY - rect.top; // y position within the element.

            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            // Calculate distance from center (-1 to 1)
            const moveX = (x - centerX) / centerX;
            const moveY = (y - centerY) / centerY;

            // Move person slightly following the mouse to create a 3D looking effect (Opposite direction)
            const intensity = 5; // Reduced intensity
            // Invert direction (-moveX, -moveY) and maintain the translate-y-1 offset (4px)
            person.style.transform = `scale(0.82) translate(${-moveX * intensity}px, ${-moveY * intensity + 4}px)`;
        });

        container.addEventListener("mouseleave", () => {
            person.style.transform = "scale(0.82) translate(0, 4px)";
        });
    }

    // Typewriter effect with punctuation pauses for more natural cadence.
    const typewriterEl = document.getElementById("typewriter-text");
    if (typewriterEl) {
        const text = typewriterEl.getAttribute("data-text") || "";
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const pauseMap = {
            ",": 1000,
            "，": 1000,
            ".": 360,
            "。": 420,
            "!": 340,
            "！": 380,
            "?": 340,
            "？": 380,
            ";": 280,
            "；": 320,
            ":": 260,
            "：": 300,
        };
        let i = 0;

        const getDelay = (char) => {
            if (char in pauseMap) return pauseMap[char];
            if (char === " ") return 45;
            return 82 + Math.floor(Math.random() * 36);
        };

        const typeNext = () => {
            if (i >= text.length) return;

            const char = text.charAt(i);
            typewriterEl.textContent += char;
            i++;

            if (i < text.length) {
                window.setTimeout(typeNext, getDelay(char));
            }
        };

        if (prefersReducedMotion) {
            typewriterEl.textContent = text;
        } else {
            window.setTimeout(typeNext, 280);
        }
    }
</script>
