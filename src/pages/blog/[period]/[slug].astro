---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import PostHeader from '../../../components/blog/PostHeader.astro';
import TableOfContents from '../../../components/blog/TableOfContents.astro';
import PostNav from '../../../components/blog/PostNav.astro';
import Comments from '../../../components/blog/Comments.astro';
import ImageLightbox from '../../../components/ImageLightbox.astro';

const allPosts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

function getPostUrl(id: string) {
  const parts = id.split('/');
  return `/blog/${parts[0]}/${parts[1]}`;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'en');
  return posts.map((post) => {
    const parts = post.id.split('/');
    return {
      params: { period: parts[0], slug: parts[1] },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const { period, slug } = Astro.params;
const zhUrl = `/zh/blog/${period}/${slug}`;
const currentUrl = `/blog/${period}/${slug}`;

// allPosts is sorted newest-first; lower index = more recent.
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : undefined;
---

<Layout title={`${post.data.title} — Ethan Zhao`}>
  <div class="blog-page">
    <aside class="blog-toc-float">
      <TableOfContents headings={headings} lang="en" listUrl="/blog" currentUrl={currentUrl} />
    </aside>

    <main class="max-w-4xl mx-auto px-5 sm:px-8 pt-10 sm:pt-16 pb-16">
      <PostHeader post={post} body={post.body ?? ''} lang="en" switchUrl={zhUrl} listUrl="/blog" currentUrl={currentUrl} />
      <article class="prose prose-base sm:prose-lg max-w-none prose-p:leading-[1.65] prose-headings:tracking-tight prose-p:text-[var(--text-primary)] prose-headings:text-[var(--text-primary)]"
        style="animation: fadeInContent 600ms 200ms ease-out both;">
        <Content />
      </article>
      <PostNav
        lang="en"
        listUrl="/blog"
        currentUrl={currentUrl}
        newerPost={newerPost ? { title: newerPost.data.title, url: getPostUrl(newerPost.id) } : undefined}
        olderPost={olderPost ? { title: olderPost.data.title, url: getPostUrl(olderPost.id) } : undefined}
      />
      <Comments lang="en" term={`blog/${period}/${slug}`} />
      <ImageLightbox />
    </main>
  </div>
  <Footer />
</Layout>

<style>
  .blog-page {
    position: relative;
  }

  .blog-toc-float {
    display: none;
  }

  @media (min-width: 1280px) {
    .blog-toc-float {
      display: block;
      position: fixed;
      top: 6rem;
      left: max(1rem, calc((100vw - 48rem) / 2 - 16rem));
      width: 13rem;
    }
  }

  @keyframes fadeInContent {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
