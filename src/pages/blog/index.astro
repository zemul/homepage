---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

function getPostUrl(id: string) {
  const parts = id.split('/');
  return `/blog/${parts[0]}/${parts[1]}`;
}

function formatDate(dateStr: string) {
  const [year, month] = dateStr.split('-');
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${monthNames[parseInt(month) - 1]} ${year}`;
}
---

<Layout title={`Blog — Ethan Zhao`}>
  <main class="max-w-3xl mx-auto px-5 sm:px-8 pt-20 sm:pt-28 pb-16">

    <!-- Page header -->
    <header class="mb-16 sm:mb-24">
      <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-[var(--muted-text)]">
        {t('blog.kicker')}
      </span>
      <h1
        class="font-display mt-4 text-[2.75rem] sm:text-[3.5rem] text-[var(--text-primary)] text-balance"
        style="font-weight: 500; line-height: 1.05; letter-spacing: -0.025em;"
      >
        {t('blog.title')}
      </h1>
      <p class="blog-lead mt-5 max-w-xl text-base sm:text-lg text-[var(--text-secondary)]" style="line-height: 1.55;">
        {t('blog.subtitle')}
      </p>
      <div class="mt-10 h-px bg-[var(--border-subtle)]"></div>
    </header>

    <!-- Post list -->
    <ul class="space-y-0">
      {posts.map((post, index) => (
        <li class="post-row group" data-post-url={getPostUrl(post.id)} style={`animation: fadeInUp 400ms ${index * 60}ms both ease-out;`}>
          <a
            href={getPostUrl(post.id)}
            class="block px-4 sm:px-5 -mx-4 sm:-mx-5 py-7 sm:py-8 rounded-xl transition-colors duration-200"
          >
            {/* Meta line: date · tags */}
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-3">
              <time class="font-mono text-[11px] tracking-[0.16em] uppercase text-[var(--muted-text)]" style="font-feature-settings: 'tnum';">
                {formatDate(post.data.date)}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span class="w-1 h-1 rounded-full bg-[var(--border-subtle)]" aria-hidden="true"></span>
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="badge-pill">{tag}</span>
                    ))}
                  </div>
                </>
              )}
            </div>

            {/* Title */}
            <h2
              class="post-title font-display text-2xl sm:text-[1.75rem] text-[var(--text-primary)] leading-tight"
              style="font-weight: 500; letter-spacing: -0.02em;"
            >
              {post.data.title}
            </h2>

            {/* Description */}
            {post.data.description && (
              <p class="text-[15px] sm:text-base text-[var(--text-secondary)] mt-3 leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            )}

            {/* Read more indicator */}
            <span class="inline-flex items-center gap-1.5 mt-4 font-mono text-[11px] tracking-[0.12em] uppercase text-[var(--accent)] transition-transform duration-200 group-hover:translate-x-1">
              {t('blog.readMore')}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>

  </main>
  <Footer />
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Restore scroll position to the post the user came back from
  const target = sessionStorage.getItem('blog-scroll-target');
  if (target) {
    sessionStorage.removeItem('blog-scroll-target');
    requestAnimationFrame(() => {
      const el = document.querySelector(`[data-post-url="${target}"]`);
      if (el) {
        el.scrollIntoView({ block: 'center', behavior: 'instant' });
      }
    });
  }
</script>
