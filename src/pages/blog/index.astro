---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

function getPostUrl(id: string) {
  const parts = id.split('/');
  return `/blog/${parts[0]}/${parts[1]}`;
}

function formatDate(dateStr: string) {
  const [year, month] = dateStr.split('-');
  const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${monthNames[parseInt(month) - 1]} ${year}`;
}
---

<Layout title={`Blog — Ethan Zhao`}>
  <main class="max-w-3xl mx-auto px-5 sm:px-8 pt-20 sm:pt-28 pb-16">

    <!-- Page header -->
    <header class="mb-14 sm:mb-20">
      <div class="flex items-center gap-4 mb-6">
        <div class="relative w-12 h-12 rounded-full overflow-hidden shrink-0 ring-2 ring-[var(--border-subtle)]">
          <div class="absolute inset-0 bg-[url('/bg.png')] bg-cover bg-center"></div>
          <div class="absolute inset-0 bg-[url('/person.png')] bg-cover bg-center" style="transform: scale(0.82) translate(0, 4px);"></div>
        </div>
        <div>
          <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight text-[var(--text-primary)]" style="letter-spacing: -0.03em;">Blog</h1>
          <p class="text-sm text-[var(--muted-text)] mt-0.5">{t('blog.subtitle')}</p>
        </div>
      </div>
      <div class="h-px bg-[var(--border-subtle)]"></div>
    </header>

    <!-- Post list -->
    <ul class="space-y-0">
      {posts.map((post, index) => (
        <li class="group" data-post-url={getPostUrl(post.id)} style={`animation: fadeInUp 400ms ${index * 60}ms both ease-out;`}>
          <a
            href={getPostUrl(post.id)}
            class="block py-6 sm:py-7 border-b border-[var(--border-subtle)] transition-colors duration-200 hover:border-[var(--accent)]"
          >
            {/* Date + Tags row */}
            <div class="flex items-center gap-3 mb-2.5">
              <time class="font-mono text-xs tracking-wide uppercase text-[var(--muted-text)]" style="font-feature-settings: 'tnum';">
                {formatDate(post.data.date)}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span class="w-1 h-1 rounded-full bg-[var(--border-subtle)]" aria-hidden="true"></span>
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="font-mono text-[10px] tracking-wider uppercase text-[var(--muted-text)] px-1.5 py-0.5 rounded bg-[var(--panel-subtle)]">
                      {tag}
                    </span>
                  ))}
                </>
              )}
            </div>

            {/* Title */}
            <h2 class="font-display text-lg sm:text-xl font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors duration-200 leading-snug tracking-tight">
              {post.data.title}
            </h2>

            {/* Description */}
            {post.data.description && (
              <p class="text-sm text-[var(--text-secondary)] mt-2 leading-relaxed line-clamp-2" style="max-width: 540px;">
                {post.data.description}
              </p>
            )}

            {/* Read more indicator */}
            <span class="inline-flex items-center gap-1 mt-3 text-xs font-medium text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-all duration-200 translate-x-0 group-hover:translate-x-1">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>

  </main>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Restore scroll position to the post the user came back from
  const target = sessionStorage.getItem('blog-scroll-target');
  if (target) {
    sessionStorage.removeItem('blog-scroll-target');
    requestAnimationFrame(() => {
      const el = document.querySelector(`[data-post-url="${target}"]`);
      if (el) {
        el.scrollIntoView({ block: 'center', behavior: 'instant' });
      }
    });
  }
</script>
