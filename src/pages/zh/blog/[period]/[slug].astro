---
import { getCollection, render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import PostHeader from '../../../../components/blog/PostHeader.astro';
import TableOfContents from '../../../../components/blog/TableOfContents.astro';
import Comments from '../../../../components/blog/Comments.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'zh');
  return posts.map((post) => {
    const parts = post.id.split('/');
    return {
      params: { period: parts[0], slug: parts[1] },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const { period, slug } = Astro.params;
const enUrl = `/blog/${period}/${slug}`;
---

<Layout title={`${post.data.title} — 小哲`}>
  <div class="blog-page">
    <!-- TOC floats in left margin on wide screens -->
    <aside class="blog-toc-float">
      <TableOfContents headings={headings} lang="zh" />
    </aside>

    <!-- Content area stays centered -->
    <main class="max-w-2xl mx-auto px-5 sm:px-8 pt-16 sm:pt-24 pb-16">
      <PostHeader post={post} body={post.body ?? ''} lang="zh" switchUrl={enUrl} />
      <article class="prose prose-base sm:prose-lg max-w-none prose-p:leading-[1.8] prose-headings:tracking-tight prose-p:text-[var(--text-primary)] prose-headings:text-[var(--text-primary)]"
        style="animation: fadeInContent 600ms 200ms ease-out both;">
        <Content />
      </article>
      <Comments lang="zh" term={`blog/${period}/${slug}`} />
    </main>
  </div>
</Layout>

<style>
  .blog-page {
    position: relative;
  }

  .blog-toc-float {
    display: none;
  }

  @media (min-width: 1280px) {
    .blog-toc-float {
      display: block;
      position: fixed;
      top: 6rem;
      left: max(1rem, calc((100vw - 42rem) / 2 - 16rem));
      width: 13rem;
    }
  }

  @keyframes fadeInContent {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
