---
import "../styles/global.css";
import TopNav from "../components/blog/TopNav.astro";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

interface Props {
    title: string;
    noindex?: boolean;
    preloadImages?: string[];
}

const { title, noindex = false, preloadImages = [] } = Astro.props;

const pathname = Astro.url.pathname;
const isBlogRoute =
    pathname === "/blog" ||
    pathname.startsWith("/blog/") ||
    pathname === "/zh/blog" ||
    pathname.startsWith("/zh/blog/");
const routeClass = isBlogRoute ? "route-blog" : "";
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Ethan Zhao - AI-Driven Product Builder" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <link rel="icon" type="image/png" href="/yizhe.png" />
        <meta name="generator" content={Astro.generator} />
        {noindex && <meta name="robots" content="noindex,nofollow" />}
        <title>{title}</title>

        <!-- PWA / Mobile optimization -->
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <meta name="apple-mobile-web-app-title" content="Ethan Zhao" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="theme-color" content="#faf8f5" media="(prefers-color-scheme: light)" />
        <meta name="theme-color" content="#111110" media="(prefers-color-scheme: dark)" />
        <link rel="apple-touch-icon" href="/favorite.png" />
        <link rel="manifest" href="/manifest.webmanifest" />

        <!-- Web fonts: kept in <head> so Vite doesn't strip the cross-origin @import -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Source+Serif+4:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Noto+Serif+SC:wght@400;500;600&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        />

        {preloadImages.map((href) => (
            <link rel="preload" as="image" href={href} type="image/webp" />
        ))}
    </head>
    <body
        class:list={["noise-overlay min-h-screen bg-[var(--page-bg)] text-[var(--text-primary)] antialiased transition-[background-color,color] duration-300 overscroll-none touch-pan-y site-shell", routeClass]}
        style="padding-bottom: env(safe-area-inset-bottom); font-family: 'Inter', system-ui, -apple-system, sans-serif;"
    >
        <TopNav />
        <slot />
    </body>
</html>

<style is:global>
    html,
    body {
        margin: 0;
        width: 100%;
    }
    html {
        height: 100%;
    }
    /* Sticky footer: body fills the viewport, main expands, footer hugs bottom. */
    body.site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
    body.site-shell > main {
        flex: 1 0 auto;
    }
    body.site-shell > footer {
        flex: 0 0 auto;
    }
</style>
